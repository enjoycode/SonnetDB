{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5080"
      }
    }
  },
  "SonnetDBServer": {
    "DataRoot": "./sonnetdb-data",
    "AutoLoadExistingDatabases": true,
    "AllowAnonymousProbes": true
  },
  "SonnetDBServer_Ai_Example": {
    "_comment": "AI 配置在运行时通过 /v1/admin/ai-config 管理，持久化到 <DataRoot>/.system/ai-config.json。以下为参考格式。",
    "Enabled": false,
    "Provider": "ollama",
    "BaseUrl": "http://localhost:11434",
    "ApiKey": "",
    "Model": "llama3.2",
    "TimeoutSeconds": 60
  }
}
